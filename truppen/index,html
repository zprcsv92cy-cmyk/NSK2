<!doctype html>
<html lang="sv">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Truppen Team 18</title>
  <link rel="stylesheet" href="/NSK2/app.css">
  <style>
    .sheet{
      max-width:860px;margin:18px auto 40px;background:#f2f2f2;border-radius:34px;
      padding:28px 22px;box-shadow:0 18px 40px rgba(0,0,0,.35);color:#111;
    }
    .sheet-top{display:flex;justify-content:space-between;align-items:flex-start;gap:16px;margin-bottom:12px}
    .sheet-title{color:#e7e7e7;font-size:26px;font-weight:900;margin:8px 0 0 8px}
    .close-btn{
      width:92px;height:92px;display:flex;align-items:center;justify-content:center;border-radius:24px;
      border:1px solid #7f0d1a;background:linear-gradient(180deg,#d51f35,#9f0d20);color:#fff;
      font-size:52px;font-weight:900;text-decoration:none;box-shadow:0 12px 24px rgba(0,0,0,.28);flex:0 0 auto;
    }
    .block{
      background:linear-gradient(180deg,#21232a,#17191f);color:#fff;border-radius:30px;padding:26px 28px;
      border:1px solid #2e3038;box-shadow:0 12px 24px rgba(0,0,0,.18);margin-bottom:20px;
    }
    .block h2{margin:0 0 14px;font-size:28px;font-weight:900}
    .name-input{
      width:100%;padding:18px 20px;margin:0 0 14px;border-radius:20px;border:1px solid #2b2d33;
      background:#2a2c33;color:#fff;font-size:20px;
    }
    .big-add{
      width:100%;min-height:86px;border-radius:24px;border:1px solid #7f0d1a;
      background:linear-gradient(180deg,#e11d3d,#9f0d20);color:#fff;font-size:22px;font-weight:900;
      box-shadow:0 8px 18px rgba(0,0,0,.24);cursor:pointer;
    }
    .person-row{
      display:grid;grid-template-columns:minmax(0,1fr) 168px 148px;gap:16px;align-items:center;
      padding:18px 0;border-top:2px solid rgba(255,255,255,.9);
    }
    .person-name{font-size:28px;line-height:1.18;word-break:break-word}
    .row-btn{
      min-height:84px;border-radius:22px;border:1px solid #2c2f36;background:linear-gradient(180deg,#272a31,#1e2026);
      color:#fff;font-size:22px;font-weight:900;cursor:pointer;
    }
    .muted-note{margin-top:14px;color:#a7a7ad;font-size:18px}
    .backup-title{margin:0 0 6px;font-size:24px;font-weight:900}
    .backup-sub{color:#a7a7ad;font-size:18px;margin:0 0 18px}
    .export-btn{
      min-width:260px;min-height:78px;border-radius:22px;border:1px solid #2c2f36;background:linear-gradient(180deg,#272a31,#1e2026);
      color:#fff;font-size:20px;font-weight:900;cursor:pointer;margin-bottom:18px;
    }
    .file-label{display:block;color:#a7a7ad;font-size:18px;margin-bottom:10px}
    .file-input-wrap{
      width:100%;padding:14px 16px;border-radius:18px;border:1px solid #2b2d33;background:#2a2c33;color:#fff;font-size:18px;
    }
    .toolbar-small{display:flex;gap:10px;align-items:center;justify-content:space-between;flex-wrap:wrap;margin-bottom:8px}
    .mini-msg{color:#a7a7ad;font-size:16px}
    .hidden{display:none}
    @media (max-width:900px){
      .sheet{margin:14px;padding:18px 12px;border-radius:26px}
      .close-btn{width:72px;height:72px;font-size:40px;border-radius:20px}
      .block{padding:18px 16px;border-radius:24px}
      .sheet-title{font-size:22px}
      .person-row{grid-template-columns:minmax(0,1fr) 1fr 1fr;gap:10px}
      .person-name{font-size:24px}
      .row-btn{min-height:74px;font-size:18px}
    }
    @media (max-width:680px){
      .person-row{grid-template-columns:minmax(0,1fr) 150px 130px}
      .person-name{font-size:22px}
    }
  </style>
</head>
<body>
  <div class="sheet">
    <div class="sheet-top">
      <div class="sheet-title">Truppen team 18</div>
      <a class="close-btn" href="/NSK2/startsida/" aria-label="Stäng">×</a>
    </div>

    <section class="block">
      <div class="toolbar-small">
        <h2>Spelare</h2>
        <div id="playersMsg" class="mini-msg"></div>
      </div>
      <input id="playerInput" class="name-input" placeholder="Förnamn Efternamn">
      <button id="addPlayerBtn" class="big-add">Lägg till</button>
      <div id="playersList"></div>
      <div class="muted-note">Sorteras A–Ö. Sparas i telefonen.</div>
    </section>

    <section class="block">
      <div class="toolbar-small">
        <h2>Tränare</h2>
        <div id="coachesMsg" class="mini-msg"></div>
      </div>
      <input id="coachInput" class="name-input" placeholder="Förnamn Efternamn">
      <button id="addCoachBtn" class="big-add">Lägg till</button>
      <div id="coachesList"></div>
      <div class="muted-note">Sorteras A–Ö. Sparas i telefonen.</div>
    </section>

    <section class="block">
      <div class="backup-title">Backup / Flytta till annan telefon</div>
      <div class="backup-sub">Export/Import av register + alla poolspel.</div>
      <button id="exportBtn" class="export-btn">Exportera JSON</button>
      <label class="file-label">Importera JSON</label>
      <div class="file-input-wrap">
        <input id="importFile" type="file" accept="application/json">
      </div>
      <div id="backupMsg" class="muted-note"></div>
    </section>
  </div>

  <script>
    (() => {
      const KEY = "nsk2_trupp_v1";
      const defaultState = {
        players: [
          "Agnes Danielsson","Albert Zillén","Albin Andersson","Aron Warensjö-Sommar","August Hasselberg",
          "Benjamin Linderström","Charlie Carman","Emil Tranborg","Enzo Olsson","Gunnar Englund",
          "Henry Gauffin","Linus Stolt","Melker Axbom","Måns Åkvist","Nelson Östergren",
          "Nicky Selander","Nikola Kosoderc","Noé Bonnafous Sand","Oliver Engström","Oliver Zoumblïos",
          "Pelle Åstrand","Simon Misiorny","Sixten Bratt","Theo Ydrenius","Viggo Kronvall","Yuktha reddy Semberi"
        ],
        coaches: [
          "Fredrik Selander","Joakim Lund","Linus Öhman","Niklas Gauffin","Olle Åstrand","Peter Hasselberg","Tommy Englund","William Åkvist"
        ]
      };

      function load() {
        try {
          const saved = JSON.parse(localStorage.getItem(KEY) || "null");
          return saved && typeof saved === "object" ? saved : structuredClone(defaultState);
        } catch {
          return structuredClone(defaultState);
        }
      }

      const state = load();

      function save() {
        localStorage.setItem(KEY, JSON.stringify(state));
      }

      function byId(id){ return document.getElementById(id); }
      function esc(s){
        return String(s ?? "").replace(/[&<>"]/g, m => ({ "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;" }[m]));
      }
      function norm(s){ return String(s || "").trim(); }
      function setMsg(id, text){
        const el = byId(id);
        if (el) el.textContent = text || "";
      }

      function sorted(list){
        return [...list].sort((a,b) => a.localeCompare(b, "sv"));
      }

      function renderList(containerId, items, type){
        const box = byId(containerId);
        if (!box) return;
        const rows = sorted(items).map(name => `
          <div class="person-row">
            <div class="person-name">${esc(name)}</div>
            <button class="row-btn" data-edit="${type}" data-name="${encodeURIComponent(name)}">Redigera</button>
            <button class="row-btn" data-remove="${type}" data-name="${encodeURIComponent(name)}">Ta bort</button>
          </div>
        `).join("");
        box.innerHTML = rows || `<div class="muted-note">Inga ${type === "player" ? "spelare" : "tränare"} ännu.</div>`;
      }

      function render(){
        renderList("playersList", state.players, "player");
        renderList("coachesList", state.coaches, "coach");
      }

      function addItem(type, inputId, msgId){
        const input = byId(inputId);
        const name = norm(input?.value);
        if (!name) return setMsg(msgId, "Skriv ett namn.");
        const list = type === "player" ? state.players : state.coaches;
        if (list.some(x => x.toLowerCase() === name.toLowerCase())) return setMsg(msgId, "Finns redan.");
        list.push(name);
        save();
        render();
        input.value = "";
        setMsg(msgId, "Sparad.");
      }

      function removeItem(type, name){
        const decoded = decodeURIComponent(name);
        const list = type === "player" ? state.players : state.coaches;
        const idx = list.findIndex(x => x === decoded);
        if (idx >= 0) {
          list.splice(idx, 1);
          save();
          render();
        }
      }

      function editItem(type, name){
        const decoded = decodeURIComponent(name);
        const next = prompt("Redigera namn", decoded);
        const clean = norm(next);
        if (!clean || clean === decoded) return;
        const list = type === "player" ? state.players : state.coaches;
        const idx = list.findIndex(x => x === decoded);
        if (idx >= 0) {
          list[idx] = clean;
          save();
          render();
        }
      }

      function exportJson(){
        const payload = JSON.stringify(state, null, 2);
        const blob = new Blob([payload], { type: "application/json" });
        const url = URL.createObjectURL(blob);
        const a = document.createElement("a");
        a.href = url;
        a.download = "nsk2-trupp-backup.json";
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        setMsg("backupMsg", "Export klar.");
      }

      function importJson(file){
        const reader = new FileReader();
        reader.onload = () => {
          try {
            const data = JSON.parse(String(reader.result || "{}"));
            if (!Array.isArray(data.players) || !Array.isArray(data.coaches)) throw new Error("Fel format");
            state.players = data.players.map(norm).filter(Boolean);
            state.coaches = data.coaches.map(norm).filter(Boolean);
            save();
            render();
            setMsg("backupMsg", "Import klar.");
          } catch {
            setMsg("backupMsg", "Kunde inte läsa filen.");
          }
        };
        reader.readAsText(file);
      }

      byId("addPlayerBtn").addEventListener("click", () => addItem("player", "playerInput", "playersMsg"));
      byId("addCoachBtn").addEventListener("click", () => addItem("coach", "coachInput", "coachesMsg"));
      byId("playerInput").addEventListener("keydown", e => { if (e.key === "Enter") addItem("player", "playerInput", "playersMsg"); });
      byId("coachInput").addEventListener("keydown", e => { if (e.key === "Enter") addItem("coach", "coachInput", "coachesMsg"); });
      byId("exportBtn").addEventListener("click", exportJson);
      byId("importFile").addEventListener("change", e => {
        const file = e.target.files && e.target.files[0];
        if (file) importJson(file);
      });

      document.addEventListener("click", e => {
        const t = e.target;
        if (!(t instanceof HTMLElement)) return;
        if (t.dataset.remove) removeItem(t.dataset.remove, t.dataset.name);
        if (t.dataset.edit) editItem(t.dataset.edit, t.dataset.name);
      });

      render();
    })();
  </script>
</body>
</html>
